{
  "name": "filesystem-server",
  "display_name": "File System MCP Server",
  "description": "操作本地文件系统，支持文件读写、列出文件、搜索内容等功能",
  "version": "1.0.0",
  "category": "filesystem",
  "transport": "stdio",
  "language": "python",
  "filesystem": {
    "allowed_directories": ["./workspace"],
    "allowed_extensions": [".txt", ".md", ".json", ".csv", ".py"],
    "max_file_size_mb": 10,
    "allow_write": true,
    "allow_delete": false
  },
  "tools": [
    {
      "name": "list_files",
      "description": "列出目录下的文件",
      "parameters": [
        {
          "name": "directory",
          "type": "string",
          "description": "目录路径",
          "required": false,
          "default": "."
        },
        {
          "name": "pattern",
          "type": "string",
          "description": "文件名匹配模式，如 *.py",
          "required": false,
          "default": "*.*"
        }
      ]
    },
    {
      "name": "read_file",
      "description": "读取文件内容",
      "parameters": [
        {
          "name": "path",
          "type": "string",
          "description": "文件路径",
          "required": true
        }
      ]
    },
    {
      "name": "write_file",
      "description": "写入文件",
      "parameters": [
        {
          "name": "path",
          "type": "string",
          "description": "文件路径",
          "required": true
        },
        {
          "name": "content",
          "type": "string",
          "description": "文件内容",
          "required": true
        }
      ]
    },
    {
      "name": "search_in_files",
      "description": "在文件中搜索文本",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "搜索关键词",
          "required": true
        },
        {
          "name": "directory",
          "type": "string",
          "description": "搜索目录",
          "required": false,
          "default": "."
        },
        {
          "name": "file_pattern",
          "type": "string",
          "description": "文件匹配模式",
          "required": false,
          "default": "*.*"
        }
      ]
    }
  ],
  "ide_targets": ["trae", "cursor"],
  "generate_skill": true,
  "generate_tests": true
}
